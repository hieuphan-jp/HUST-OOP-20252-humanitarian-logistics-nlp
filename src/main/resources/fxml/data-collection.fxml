<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- KHUNG CHÍNH: Nền tối -->
<VBox xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.disaster.analysis.ui.controller.DataCollectionController"
      spacing="0" style="-fx-background-color: #020617; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- HEADER: Tiêu đề trang và tên Project -->
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-padding: 0 30 0 30; -fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 0 0 1 0;">
        <children>
            <VBox alignment="CENTER_LEFT">
                <Label fx:id="projectNameLabel" text="Project: Loading..." style="-fx-text-fill: #ffffff; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" text="SYSTEM READY" style="-fx-text-fill: #34d399; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-color: rgba(52, 211, 153, 0.1); -fx-padding: 5 12 5 12; -fx-background-radius: 20; -fx-border-color: #34d399; -fx-border-radius: 20;"/>
        </children>
    </HBox>

    <!-- NỘI DUNG CUỘN -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="25" style="-fx-padding: 25;">

                <!-- CARD THÔNG TIN DỰ ÁN -->
                <VBox spacing="15" style="-fx-background-color: #1e293b; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #334155;">
                    <children>
                        <Label text="COLLECTION PARAMETERS" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <GridPane hgap="30" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="Disaster Type:" style="-fx-text-fill: #94a3b8;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="projectDisasterNameLabel" text="-" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Platforms:" style="-fx-text-fill: #94a3b8;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="projectPlatformLabel" text="-" style="-fx-text-fill: #38bdf8; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Time Period:" style="-fx-text-fill: #94a3b8;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label fx:id="projectPeriodLabel" text="-" style="-fx-text-fill: #f8fafc;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <!-- KHU VỰC ĐIỀU KHIỂN & TIẾN TRÌNH -->
                <VBox spacing="15">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Button fx:id="startButton" text="▶ Start Collection" onAction="#handleStart" prefHeight="40" prefWidth="160"
                                style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button fx:id="stopButton" text="⏹ Stop" onAction="#handleStop" disable="true" prefHeight="40" prefWidth="160"
                                style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- THANH TIẾN TRÌNH -->
                    <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                        <HBox>
                            <Label text="Collection Progress" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="progressDetailsLabel" text="0%" style="-fx-text-fill: #38bdf8; -fx-font-weight: bold;"/>
                        </HBox>
                        <ProgressBar fx:id="progressBar" progress="0.0" maxWidth="Infinity" prefHeight="10"
                                     style="-fx-accent: #38bdf8; -fx-background-color: #0f172a; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                    </VBox>
                </VBox>

                <!-- DANH SÁCH BÀI ĐĂNG THU THẬP (LIST VIEW) -->
                <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: #0f172a; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #1e293b;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="COLLECTED POSTS" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="REAL-TIME" style="-fx-text-fill: #ef4444; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- LISTVIEW DARK MODE -->
                        <ListView fx:id="postsListView" VBox.vgrow="ALWAYS" prefHeight="350.0"
                                  style="-fx-background-color: #0f172a;
                                  -fx-padding: 2;
                                  -fx-control-inner-background: white;
                                  -fx-control-inner-background-alt: white;
                                  -fx-text-fill: black;
                                  -fx-font-family: 'Consolas', monospace;
                                  -fx-font-size: 12px;
                                  -fx-border-color: #334155;
                                  -fx-border-radius: 5;"/>
                    </children>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <!-- FOOTER: Nút Back -->
    <HBox prefHeight="70.0" alignment="CENTER_LEFT" style="-fx-padding: 0 30 0 30; -fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 1 0 0 0;">
        <children>
            <Button fx:id="backButton" text="← Back to Projects" onAction="#handleBack"
                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 20 8 20;"/>
        </children>
    </HBox>

</VBox>