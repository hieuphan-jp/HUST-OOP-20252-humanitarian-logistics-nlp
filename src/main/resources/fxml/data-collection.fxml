<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.disaster.analysis.ui.controller.DataCollectionController"
      spacing="20" styleClass="content-container">

    <!-- Header -->
    <HBox alignment="CENTER" spacing="10">
        <Label fx:id="projectNameLabel" text="Project Name" styleClass="header"/>
    </HBox>

    <!-- Project Info -->
    <VBox spacing="5" styleClass="card">
        <!-- <Label fx:id="projectNameLabel" text="Project: " styleClass="section-title"/> -->
        <Label fx:id="projectDisasterNameLabel" text="Disaster: " styleClass="secondary" wrapText="true"/>
        <Label fx:id="projectPlatformLabel" text="Platform: " styleClass="secondary" wrapText="true"/>
        <Label fx:id="projectPeriodLabel" text="Period: " styleClass="secondary" wrapText="true"/>
        <!-- <Label fx:id="projectDetailsLabel" text="" styleClass="secondary" wrapText="true"/> -->
    </VBox>

    <HBox spacing="10">
        <Button fx:id="startButton" text="Collect" onAction="#handleStart" styleClass="success"/>
        <Button fx:id="stopButton" text="Stop" onAction="#handleStop" disable="true" styleClass="danger"/>
        <!-- <Button text="Analyze" onAction="#handleAnalyze" styleClass="primary"/> -->
    </HBox>

    <!-- Progress Section -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">

        <!-- Status Label -->
        <Label fx:id="statusLabel" text="Ready to collect data" styleClass="section-title"/>

        <!-- Collected Posts List -->
        <VBox spacing="5" VBox.vgrow="ALWAYS">
            <Label text="Collected Posts" styleClass="section-title"/>
            <ListView fx:id="postsListView" VBox.vgrow="ALWAYS"/>
        </VBox>

    </VBox>


    <StackPane>
        <!-- Progress Bar -->
        <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity" prefHeight="25"/>

        <!-- Progress Details -->
        <Label fx:id="progressDetailsLabel" text="Ready to collect" styleClass="secondary"/>
    </StackPane>


    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="backButton" text="Back to Projects" onAction="#handleBack" styleClass="secondary"/>
        <!-- <Button fx:id="stopButton" text="Stop" onAction="#handleStop" disable="true" styleClass="danger"/> -->
        <!-- <Button fx:id="startButton" text="Start Collection" onAction="#handleStart" styleClass="success"/> -->
    </HBox>

</VBox>