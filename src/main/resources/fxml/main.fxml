<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainPane" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.disaster.analysis.ui.controller.MainController"
            prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color: #020617;">

    <top>
        <!-- Nhấn Exit là thoát -->
        <HBox alignment="CENTER_LEFT" prefHeight="40.0"
              style="-fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="10" />
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#handleExit" text="Exit"
                        style="-fx-background-color: transparent; -fx-text-fill: #f8fafc; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 5 15 5 15; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>

    <center>
        <BorderPane fx:id="contentArea" style="-fx-background-color: #020617;">
            <center>
                <Label text="Welcome to Disaster Social Media Analysis"
                       style="-fx-font-size: 24px; -fx-text-fill: #475569;"/>
            </center>
        </BorderPane>
    </center>

    <bottom>
        <HBox fx:id="statusBar" alignment="CENTER_LEFT" spacing="10"
              style="-fx-padding: 8 15 8 15; -fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 1 0 0 0;">
            <children>
                <Label fx:id="statusLabel" text="Ready" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
