<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.disaster.analysis.ui.controller.AnalysisController"
      spacing="20" styleClass="content-container">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Analysis" styleClass="header"/>
    </HBox>

    <!-- Project Info -->
    <VBox spacing="5" styleClass="card">
        <Label fx:id="projectNameLabel" text="Project: " styleClass="section-title"/>
        <Label fx:id="projectDetailsLabel" text="" styleClass="secondary" wrapText="true"/>
    </VBox>

    <!-- Analysis TabPane -->
    <TabPane fx:id="analysisTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Sentiment Analysis Tab -->
        <Tab text="Sentiment Analysis">
            <VBox spacing="15" style="-fx-padding: 15;">

                <!-- Controls Section -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Time Granularity:" styleClass="section-title"/>
                    <ComboBox fx:id="timeGranularityComboBox"
                              promptText="Select granularity"
                              onAction="#handleTimeGranularityChange"
                              prefWidth="150"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="runSentimentButton" text="Run Sentiment Analysis"
                            onAction="#handleRunSentimentAnalysis"/>
                </HBox>

                <!-- Sentiment Chart -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <Label text="Sentiment Over Time" styleClass="section-title"/>
                    <LineChart fx:id="sentimentChart"
                               title="Sentiment Distribution Over Time"
                               VBox.vgrow="ALWAYS"
                               legendVisible="true"
                               animated="true">
                        <xAxis>
                            <CategoryAxis label="Time Period" side="BOTTOM"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Number of Posts" side="LEFT"/>
                        </yAxis>
                    </LineChart>
                </VBox>

                <!-- Sentiment Statistics -->
                <HBox spacing="20" alignment="CENTER" styleClass="card">
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="Positive" styleClass="secondary"/>
                        <Label fx:id="positiveCountLabel" text="0" styleClass="status-positive" style="-fx-font-size: 20px;"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="Neutral" styleClass="secondary"/>
                        <Label fx:id="neutralCountLabel" text="0" styleClass="status-neutral" style="-fx-font-size: 20px;"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="Negative" styleClass="secondary"/>
                        <Label fx:id="negativeCountLabel" text="0" styleClass="status-negative" style="-fx-font-size: 20px;"/>
                    </VBox>
                </HBox>

            </VBox>
        </Tab>

        <!-- Damage Classification Tab -->
        <Tab text="Damage Classification">
            <VBox spacing="15" style="-fx-padding: 15;">

                <!-- Controls Section -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Category Filter:" styleClass="section-title"/>
                    <ComboBox fx:id="categoryFilterComboBox"
                              promptText="Select category"
                              onAction="#handleCategoryFilterChange"
                              prefWidth="200"/>
                    <Label text="Content Type:" styleClass="section-title"/>
                    <ComboBox fx:id="contentTypeFilterComboBox"
                              promptText="Select type"
                              onAction="#handleContentTypeFilterChange"
                              prefWidth="120"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="runDamageButton" text="Run Damage Analysis"
                            onAction="#handleRunDamageAnalysis"
                            style="-fx-background-color: #FF5722;"/>
                </HBox>

                <!-- Split Pane for Chart and Sample Posts -->
                <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.6">

                    <!-- Damage Chart -->
                    <VBox spacing="5">
                        <Label text="Damage Category Distribution" styleClass="section-title"/>
                        <BarChart fx:id="damageChart"
                                  title="Damage Categories by Frequency"
                                  VBox.vgrow="ALWAYS"
                                  legendVisible="false"
                                  animated="true">
                            <xAxis>
                                <CategoryAxis label="Damage Category" side="BOTTOM"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Number of Posts" side="LEFT"/>
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- Sample Content Section -->
                    <!-- <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Sample Content" styleClass="section-title"/>
                            <Label fx:id="samplePostsCountLabel" text="(0 posts, 0 comments)" styleClass="secondary"/>
                        </HBox>
                        <ListView fx:id="samplePostsListView" VBox.vgrow="ALWAYS"/>
                    </VBox> -->

                </SplitPane>

            </VBox>
        </Tab>

        <!-- AI Summary Tab -->
        <Tab text="AI Summary">
            <VBox spacing="15" style="-fx-padding: 15;">

                <!-- Controls Section -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Button fx:id="generateSummaryButton" text="Generate AI Summary"
                            onAction="#handleGenerateSummary"
                            style="-fx-background-color: #4CAF50;"/>
                    <ProgressIndicator fx:id="summaryProgressIndicator"
                                       prefWidth="30" prefHeight="30"
                                       visible="false"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="copySummaryButton" text="Copy to Clipboard"
                            onAction="#handleCopySummary"/>
                </HBox>

                <!-- Summary Text Area -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <Label text="Generated Summary" styleClass="section-title"/>
                    <TextArea fx:id="summaryTextArea"
                              VBox.vgrow="ALWAYS"
                              editable="false"
                              wrapText="true"
                              promptText="Click 'Generate AI Summary' to create an AI-powered analysis of your project data..."
                              style="-fx-font-family: 'System'; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Metadata Section -->
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                    <Label fx:id="summaryMetadataLabel"
                           text=""
                           styleClass="secondary"
                           wrapText="true"
                           HBox.hgrow="ALWAYS"/>
                </HBox>

            </VBox>
        </Tab>

    </TabPane>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="backButton" text="Back to Projects" onAction="#handleBack" styleClass="secondary"/>
        <Button fx:id="exportButton" text="Export Results" onAction="#handleExport" styleClass="success"/>
    </HBox>

</VBox>
