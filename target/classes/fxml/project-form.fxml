<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- KHUNG CHÍNH: Nền xanh đen -->
<VBox xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.disaster.analysis.ui.controller.ProjectFormController"
      spacing="0" style="-fx-background-color: #020617; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- HEADER: Tiêu đề Form với màu xanh Cyan -->
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-padding: 0 30 0 30; -fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 0 0 1 0;">
        <children>
            <VBox alignment="CENTER_LEFT">
                <Label fx:id="formTitleLabel" text="NEW PROJECT" style="-fx-text-fill: #38bdf8; -fx-font-size: 20px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            </VBox>
        </children>
    </HBox>

    <!-- NỘI DUNG CHÍNH (Scrollable Area) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="25" style="-fx-padding: 30;">

                <!-- THẺ CHỨA FORM (Card Style) -->
                <VBox spacing="20" style="-fx-background-color: #1e293b; -fx-padding: 30; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.4), 20, 0, 0, 8);">

                    <!-- Thông tin cơ bản: Tên dự án & Tên thiên tai -->
                    <HBox spacing="20">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Project Name *" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="nameField" promptText="Enter project name"
                                       style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                            <Label fx:id="nameErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Disaster Name *" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="disasterNameField" promptText="e.g., Typhoon Yagi"
                                       style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                            <Label fx:id="disasterNameErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" visible="false" managed="false"/>
                        </VBox>
                    </HBox>

                    <!-- Keywords -->
                    <VBox spacing="8">
                        <Label text="Keywords *" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextArea fx:id="keywordsArea" promptText="Enter keywords separated by commas..."
                                  wrapText="true" prefRowCount="3"
                                  style="-fx-control-inner-background: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        <Label text="Separate multiple keywords with commas" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                        <Label fx:id="keywordsErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>

                    <!-- Hashtags -->
                    <VBox spacing="8">
                        <Label text="Hashtags" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextArea fx:id="hashtagsArea" promptText="e.g., #typhoon, #relief"
                                  wrapText="true" prefRowCount="2"
                                  style="-fx-control-inner-background: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                    </VBox>

                    <!-- Date Range -->
                    <VBox spacing="10" style="-fx-background-color: #0f172a; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #334155; -fx-border-radius: 12;">
                        <Label text="Monitoring Period (Optional)" style="-fx-text-fill: #38bdf8; -fx-font-weight: bold;"/>
                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Start Date" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                                <DatePicker fx:id="startDatePicker" maxWidth="Infinity" style="-fx-control-inner-background: #1e293b;"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="End Date" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                                <DatePicker fx:id="endDatePicker" maxWidth="Infinity" style="-fx-control-inner-background: #1e293b;"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="dateErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>

                    <!-- Platform Selection -->
                    <VBox spacing="12">
                        <Label text="Data Sources *" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <VBox fx:id="platformsContainer" spacing="10" style="-fx-padding: 5 0 0 10;">
                            <!-- Checkbox sẽ được thêm từ code Java -->
                        </VBox>
                        <Label fx:id="platformsErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>

                </VBox>

                <Label text="* Mandatory information for data stream analysis" style="-fx-text-fill: #475569; -fx-font-style: italic; -fx-font-size: 12px;"/>
            </VBox>
        </content>
    </ScrollPane>

    <!-- FOOTER: Các nút hành động -->
    <HBox spacing="15" alignment="CENTER_RIGHT" prefHeight="80.0" style="-fx-padding: 0 30 0 30; -fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 1 0 0 0;">
        <children>
            <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" prefWidth="100" prefHeight="38"
                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 8;"/>
            <Button fx:id="saveButton" text="Create Project" onAction="#handleSave" prefWidth="140" prefHeight="38"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(5, 150, 105, 0.3), 10, 0, 0, 0);"/>
        </children>
    </HBox>

</VBox>
